# Copy to .env and fill in. .env is gitignored — never commit real secrets.

# --- LiveKit Cloud (https://cloud.livekit.io) ---
# Only needed if you're running the LiveKit-SIP variant of the agent.
# Not used by the default Pipecat + Twilio path.
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=APIxxxxxxxxxxxxxx
LIVEKIT_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LIVEKIT_AGENT_NAME=rupeezy-ap-agent

# --- SIP outbound trunk (LiveKit-SIP path only) ---
SIP_OUTBOUND_TRUNK_ID=ST_xxxxxxxxxxxxx

# --- Daily.co (alternative Pipecat transport) ---
# Daily blocks international dial-out without sales approval; we ended up
# on the Twilio path. Only set this if you've been approved.
DAILY_API_KEY=

# --- Admin login (predefined for hackathon demo) ---
# These exact values are pre-filled on the /login screen.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
ADMIN_DISPLAY_NAME=Admin
ADMIN_EMAIL=admin@example.com
ADMIN_ROLE=Operations Manager
# 32+ random bytes recommended in production.
ADMIN_JWT_SECRET=replace-me-with-a-long-random-string

# --- Agent persona (configurable, no need to touch prompts.py) ---
# Change AGENT_PRONOUNS to "he/him" if you swap to a male voice — the
# Hindi verb ending in the opener (rahi vs raha) is conjugated automatically.
AGENT_NAME=Priya
AGENT_BRAND=Rupeezy
AGENT_PRONOUNS=she/her

# --- Twilio (https://www.twilio.com/console) ---
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_FROM_NUMBER=+1XXXXXXXXXX
# Default destination used by scripts/test_twilio_call.py. Trial accounts
# can only dial numbers on the Verified Caller IDs list.
TEST_TO_NUMBER=+91XXXXXXXXXX

# --- Sarvam AI (https://dashboard.sarvam.ai) ---
# Used for STT (Saarika/Saaras) and TTS (Bulbul) on the Pipecat/Twilio path.
SARVAM_API_KEY=your-sarvam-api-key
# Default speaker for TTS when a lead has no per-lead voice. Pick from:
# Female: kavya, priya, neha, pooja, ishita, shreya, simran, ritu, roopa
# Male:   shubh, rahul, amit, kabir, aayan, dev, ratan, varun, aditya
SARVAM_SPEAKER=kavya
# Optional model overrides — sensible defaults are baked in.
# SARVAM_STT_MODEL=saaras:v3       # default; best Tamil/multilingual accuracy (~19% WER)
#                                  # fallback: saarika:v2.5 (faster, less accurate)
# SARVAM_TTS_MODEL=bulbul:v3

# --- LLM ---
# Any OpenAI-compatible endpoint. Defaults below assume an io.net-hosted
# vLLM serving Kimi-K2.6. For real OpenAI: unset OPENAI_BASE_URL and use
# OPENAI_LLM_MODEL=gpt-4o-mini.
OPENAI_API_KEY=sk-replace-me
OPENAI_BASE_URL=https://your-vllm-endpoint.example.com/v1
OPENAI_LLM_MODEL=moonshotai/Kimi-K2.6
# Kimi-K2.6 / DeepSeek-R1 / other thinking models add 1–4s of "reasoning"
# latency before the first audible word. Off by default for phone-call feel.
# Set to 0 if you want chain-of-thought (e.g. for the post-call analyzer).
LLM_DISABLE_THINKING=1

# --- MLflow experiment tracking ---
# Tracks each call as an MLflow run: params (lead, provider config),
# metrics (duration, interest_level, follow_up_priority), tags (score,
# sentiment), and artifacts (transcript.json, analysis.json).
# View locally: mlflow ui --port 5001
MLFLOW_ENABLED=1
MLFLOW_TRACKING_URI=file:///./mlruns
MLFLOW_EXPERIMENT=voice-agent-calls

# --- Logging ---
CONVERSATION_LOG_DIR=logs

# --- Provider selection ---
# STT_PROVIDER=sarvam        # sarvam (default) | elevenlabs
# TTS_PROVIDER=sarvam        # sarvam (default) | elevenlabs

# --- Cost controls ---
# Twilio bills per recording-minute storage. Off by default; set to 1 only
# when you actively want call audio archived for review or the audio
# waveform visualizer.
TWILIO_RECORD_CALLS=0
